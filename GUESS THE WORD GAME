#include <stdio.h>
#include <string.h>
#include <ctype.h>

#define MAX_TRIES 6

void displayWord(char word[], char guessed[]) {
    for (int i = 0; i < strlen(word); i++) {
        if (guessed[i] == 1)
            printf("%c ", word[i]);
        else
            printf("_ ");
    }
    printf("\n");
}

int isWordGuessed(char guessed[], int length) {
    for (int i = 0; i < length; i++) {
        if (guessed[i] == 0)
            return 0;
    }
    return 1;
}

int main() {
    char word[] = "computer";  // You can change the word
    int length = strlen(word);
    char guess;
    int tries = MAX_TRIES;

    int guessed[length];
    for (int i = 0; i < length; i++) {
        guessed[i] = 0;
    }

    printf("🎯 Welcome to Guess the Word Game!\n");

    while (tries > 0) {
        printf("\nWord: ");
        displayWord(word, guessed);

        printf("Enter a letter: ");
        scanf(" %c", &guess);
        guess = tolower(guess);

        int found = 0;

        for (int i = 0; i < length; i++) {
            if (word[i] == guess && guessed[i] == 0) {
                guessed[i] = 1;
                found = 1;
            }
        }

        if (!found) {
            tries--;
            printf("❌ Wrong guess! Tries left: %d\n", tries);
        } else {
            printf("✅ Good guess!\n");
        }

        if (isWordGuessed(guessed, length)) {
            printf("\n🎉 Congratulations! You guessed the word: %s\n", word);
            return 0;
        }
    }

    printf("\n💀 Game Over! The word was: %s\n", word);
    return 0;
}
