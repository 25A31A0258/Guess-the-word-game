#include <stdio.h>
#include <string.h>

int main() {
    char word[] = "computer";   
    char guess;
    int length = strlen(word);
    char display[20];
    int i, attempts = 6, found;

    for(i = 0; i < length; i++) {
        display[i] = '_';
    }
    display[length] = '\0';

    printf("==== Guess the Word Game ====\n");

    while(attempts > 0) {
        printf("\nWord: %s", display);
        printf("\nAttempts left: %d", attempts);
        printf("\nEnter a letter: ");
        scanf(" %c", &guess);

        found = 0;

        for(i = 0; i < length; i++) {
            if(word[i] == guess && display[i] == '_') {
                display[i] = guess;
                found = 1;
            }
        }

        if(!found) {
            attempts--;
            printf("Wrong guess!\n");
        } else {
            printf("Correct guess!\n");
        }
        if(strcmp(word, display) == 0) {
            printf("\nCongratulations! You guessed the word: %s\n", word);
            return 0;
        }
    }

    printf("\nGame Over! The word was: %s\n", word);

    return 0;
}
